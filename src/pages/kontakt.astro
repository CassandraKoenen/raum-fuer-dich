---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<BaseLayout
  title="Kontakt"
  description="Schreib mir oder buch direkt ein kostenloses Erstgespräch. Ich melde mich innerhalb von 24 Stunden bei dir."
>
  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="section section--sand section--sm">
    <div class="container">
      <span class="label">Kontakt</span>
      <h1>Lass uns reden</h1>
      <p class="hero-lead">
        Du hast eine Frage, ein Anliegen oder möchtest einfach mal schauen,
        ob wir zueinander passen? Ich freue mich von dir zu hören.
      </p>
    </div>
  </section>

  <!-- ── FORM + ALTERNATIVES ────────────────────────────── -->
  <section class="section section--white">
    <div class="container kontakt-inner">
      <!-- Form -->
      <div>
        <SectionHeading
          label="Schreib mir"
          heading="Deine Nachricht"
          lead="Ich antworte dir innerhalb von 24 Stunden."
        />
        <ContactForm />
      </div>

      <!-- Alternatives -->
      <aside class="alternatives">
        <SectionHeading
          label="Oder direkt"
          heading="Andere Wege"
        />

        <div class="alt-list">
          <!-- Erstgespräch -->
          <a href="/kontakt" class="alt-item">
            <div class="alt-icon" aria-hidden="true">📅</div>
            <div>
              <strong>Erstgespräch buchen</strong>
              <p>20–30 Minuten, kostenlos & unverbindlich</p>
            </div>
          </a>

          <!-- WhatsApp placeholder -->
          <a href="/kontakt" class="alt-item">
            <div class="alt-icon" aria-hidden="true">💬</div>
            <div>
              <strong>WhatsApp</strong>
              <p>Schnelle Nachrichten – ich melde mich zeitnah</p>
            </div>
          </a>

          <!-- E-Mail -->
          <a href="mailto:hallo@raumfuerdich-impulse.de" class="alt-item">
            <div class="alt-icon" aria-hidden="true">✉️</div>
            <div>
              <strong>E-Mail</strong>
              <p>hallo@raumfuerdich-impulse.de</p>
            </div>
          </a>
        </div>

        <div class="response-note">
          <p>
            <strong>Antwortzeit:</strong> Ich melde mich innerhalb von
            24 Stunden – meistens schneller.
          </p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-lead {
    font-size: 1.0625rem;
    max-width: 55ch;
    margin-top: var(--space-4);
    color: var(--color-gray-600);
  }

  h1 {
    margin-top: var(--space-2);
  }

  .kontakt-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (max-width: 768px) {
    .kontakt-inner {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }
  }

  .alternatives {
    position: sticky;
    top: 5rem;
  }

  .alt-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .alt-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--color-sand);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    border: 1px solid transparent;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .alt-item:hover {
    border-color: var(--color-sage-light);
    box-shadow: var(--shadow-sm);
    color: inherit;
  }

  .alt-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .alt-item strong {
    display: block;
    font-size: 0.9375rem;
    margin-bottom: var(--space-1);
    color: var(--color-gray-900);
  }

  .alt-item p {
    font-size: 0.875rem;
    color: var(--color-gray-600);
    max-width: none;
  }

  .response-note {
    background: var(--color-sage-bg);
    border-left: 3px solid var(--color-sage);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: var(--space-4) var(--space-5);
  }

  .response-note p {
    font-size: 0.9375rem;
    color: var(--color-gray-600);
    max-width: none;
  }
</style>

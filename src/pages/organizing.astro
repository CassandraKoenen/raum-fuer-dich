---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n';
import Placeholder from '../components/Placeholder.astro';

const tr = t('de');
const o  = tr.organizing;

const processSteps = [
  { step: '01', title: 'Erstgespräch', text: 'Wir sprechen kostenlos über deine Situation und deine Wünsche.' },
  { step: '02', title: 'Planung',      text: 'Ich erstelle dir ein Angebot und wir vereinbaren einen Termin.' },
  { step: '03', title: 'Einsatz',      text: 'Wir kommen zu dir und arbeiten strukturiert durch deine Räume.' },
  { step: '04', title: 'Ergebnis',     text: 'Du bekommst ein organisiertes Zuhause mit nachhaltigen Systemen.' },
];
---

<BaseLayout
  title={o.meta.title}
  description={o.meta.description}
  lang="de"
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content" data-animate>
        <span class="label">{o.hero.label}</span>
        <h1>{o.hero.headline}</h1>
        <p class="lead">{o.hero.body}</p>
        <a href="/kontakt" class="btn-primary">Anfrage senden</a>
      </div>
    </div>
    <div class="hero-accent" aria-hidden="true"></div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       INTRO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section intro-section">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-text" data-animate>
          <h2>{o.intro.headline}</h2>
          <p class="lead">{o.intro.body}</p>
        </div>
        <div class="intro-img-wrap" data-animate data-delay="150">
          <!-- IMAGE PROMPT: Minimalist organized shelf with folded linens, natural baskets, warm light, earth tones, Scandinavian aesthetic, photorealistic -->
          <Placeholder
            label="Bild generieren: Aufgeräumtes Regal mit natürlichen Materialien, warmes Licht, minimalistisch"
            ratio="4/5"
            class="intro-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       SERVICES GRID
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section services-section">
    <div class="container">
      <div class="section-header text-center" data-animate>
        <span class="label">Was wir übernehmen</span>
        <h2>Vollständig. Durchdacht. Fertig.</h2>
      </div>
      <div class="services-grid">
        {o.services.map((service, i) => (
          <div class="service-item" data-animate data-delay={`${i * 100}`}>
            <span class="service-icon" aria-hidden="true">{service.icon}</span>
            <h4>{service.label}</h4>
            <p>{service.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       HOW IT WORKS
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section process-section">
    <div class="container">
      <div class="section-header text-center" data-animate>
        <span class="label">Ablauf</span>
        <h2>So funktioniert es</h2>
      </div>
      <ol class="process-list">
        {processSteps.map((step, i) => (
          <li class="process-step" data-animate data-delay={`${i * 100}`}>
            <span class="step-number">{step.step}</span>
            <div class="step-content">
              <h4>{step.title}</h4>
              <p>{step.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       CTA BANNER
  ═══════════════════════════════════════════════════════════════ -->
  <section class="cta-banner" data-animate>
    <div class="container cta-inner">
      <h2>{o.cta.headline}</h2>
      <p>{o.cta.body}</p>
      <a href={o.cta.ctaHref} class="btn-primary btn-lg">{o.cta.cta}</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    background: var(--color-green-bg);
    padding-top: calc(var(--section-py) + 2rem);
    padding-bottom: var(--section-py);
    overflow: hidden;
  }

  .hero-inner { position: relative; z-index: 1; }

  .hero-content { max-width: 640px; }

  .hero-content h1 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    color: var(--color-green-dark);
    margin: var(--space-4) 0 var(--space-6);
    white-space: pre-line;
  }

  .hero-content .lead {
    font-size: var(--text-md);
    color: var(--color-green);
    margin-bottom: var(--space-8);
    max-width: none;
  }

  .hero-accent {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 85% 50%, var(--color-green-stone) 0%, transparent 70%);
    pointer-events: none;
    opacity: 0.4;
  }

  /* ── Buttons ─────────────────────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-green);
    color: #fff;
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: background var(--transition), transform var(--transition);
  }
  .btn-primary:hover { background: var(--color-green-dark); transform: translateY(-1px); }
  .btn-primary.btn-lg { padding: var(--space-4) var(--space-10); font-size: var(--text-base); }

  /* ── Intro ───────────────────────────────────────────────────────── */
  .intro-section { background: var(--color-white); }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  @media (max-width: 768px) {
    .intro-grid { grid-template-columns: 1fr; gap: var(--space-8); }
  }

  .intro-text h2 {
    color: var(--color-green-dark);
    margin-bottom: var(--space-5);
  }

  .intro-text .lead { color: var(--color-green); }

  .intro-img-wrap {
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  :global(.intro-img) {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4/5;
    object-fit: cover;
    border-radius: var(--radius-lg);
    display: block;
  }

  /* ── Services ────────────────────────────────────────────────────── */
  .services-section { background: var(--color-green-subtle); }

  .section-header {
    margin-bottom: var(--space-12);
  }

  .section-header h2 { color: var(--color-green-dark); margin-top: var(--space-3); }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
  }

  .service-item {
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-8) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    box-shadow: var(--shadow-sm);
  }

  .service-icon {
    font-size: 1.75rem;
    display: block;
  }

  .service-item h4 {
    color: var(--color-green-dark);
    font-size: var(--text-base);
    font-weight: 600;
    font-family: var(--font-body);
  }

  .service-item p {
    font-size: var(--text-sm);
    color: var(--color-green);
    max-width: none;
    line-height: 1.6;
  }

  /* ── Process ─────────────────────────────────────────────────────── */
  .process-section { background: var(--color-white); }

  .process-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-12);
    counter-reset: none;
  }

  .process-step {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-8) var(--space-6);
    border: 1px solid var(--color-green-stone);
    border-radius: var(--radius-md);
    position: relative;
  }

  .step-number {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 300;
    color: var(--color-green-soft);
    line-height: 1;
  }

  .step-content h4 {
    color: var(--color-green-dark);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }

  .step-content p {
    font-size: var(--text-sm);
    color: var(--color-green);
    max-width: none;
    line-height: 1.6;
  }

  /* ── CTA Banner ──────────────────────────────────────────────────── */
  .cta-banner {
    background: var(--color-green-dark);
    padding-block: var(--section-py);
    text-align: center;
  }

  .cta-inner { max-width: 600px; }

  .cta-banner h2 {
    color: #fff;
    margin-bottom: var(--space-4);
  }

  .cta-banner p {
    color: rgba(255,255,255,0.75);
    margin-inline: auto;
    margin-bottom: var(--space-8);
    max-width: none;
  }

  .cta-banner .btn-primary {
    background: var(--color-green-soft);
    color: var(--color-green-dark);
  }
  .cta-banner .btn-primary:hover {
    background: var(--color-green-stone);
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n';
import Placeholder from '../components/Placeholder.astro';

const tr = t('de');
const f  = tr.fengshui;

const philosophyPoints = [
  { icon: '🧘', text: 'Psychologisch fundiert, nicht mystisch' },
  { icon: '🌱', text: 'Nachhaltig und alltagstauglich' },
  { icon: '💛', text: 'Individuell auf dich zugeschnitten' },
];
---

<BaseLayout
  title={f.meta.title}
  description={f.meta.description}
  lang="de"
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <!--
        IMAGE PROMPT: Serene meditation corner with a low wooden table, a white candle, dried
        lavender, a dusty plum linen cushion on a natural-fiber rug, soft morning light through
        sheer curtains. Color palette: warm ivory #F6F2F7, light lavender gray #E7DFEA, soft
        lilac #D6C7DA, dusty plum #A58BAA, deep plum #6E556F. Interior photography, elevated
        and calm. Photorealistic.
        → File: public/images/hero-feng-shui.jpg
      -->
      <Placeholder
        label="Bild generieren: Meditationsecke in Warmelfenbein & Staubrosa (#A58BAA, #F6F2F7, #D6C7DA)"
        ratio="16/9"
        class="hero-bg-img"
      />
      <div class="hero-overlay"></div>
    </div>

    <div class="container hero-inner">
      <div class="hero-content" data-animate>
        <span class="label">{f.hero.label}</span>
        <h1>{f.hero.headline}</h1>
        <p class="lead">{f.hero.body}</p>
        <a href="/kontakt" class="btn-primary">Erstgespräch buchen</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       INTRO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section intro-section">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-text" data-animate>
          <h2>{f.intro.headline}</h2>
          <p class="lead">{f.intro.body}</p>
        </div>
        <blockquote class="intro-quote" data-animate data-delay="150">
          {f.intro.quote}
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       ASPECTS
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section aspects-section">
    <div class="container">
      <div class="section-header text-center" data-animate>
        <span class="label">Was wir betrachten</span>
        <h2>Vier Dimensionen deines Raumes</h2>
      </div>
      <div class="aspects-grid">
        {f.aspects.map((aspect, i) => (
          <div class="aspect-card" data-animate data-delay={`${i * 100}`}>
            <span class="aspect-icon" aria-hidden="true">{aspect.icon}</span>
            <h4>{aspect.label}</h4>
            <p>{aspect.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       PHILOSOPHY
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section philosophy-section">
    <div class="container philosophy-inner">
      <div class="philosophy-content" data-animate>
        <span class="label">Mein Ansatz</span>
        <h2>Feng Shui, neu gedacht</h2>
        <p class="lead">Ich verbinde das uralte Wissen des Feng Shui mit moderner Raumpsychologie und Ordnungsarbeit. Das Ergebnis ist ein Ansatz, der spirituell offen, aber nicht esoterisch ist – und der sich in deinem Alltag tatsächlich anfühlt.</p>
        <div class="philosophy-points">
          {philosophyPoints.map(point => (
            <div class="philosophy-point">
              <span aria-hidden="true">{point.icon}</span>
              <span>{point.text}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="philosophy-img-wrap" data-animate data-delay="200">
        <!--
          IMAGE PROMPT: Tranquil room corner with soft lilac linen cushions, a small wooden
          shelf with crystals and dried botanicals, sheer dusty-plum curtains filtering
          afternoon light. Color palette: warm ivory #F6F2F7, light lavender gray #E7DFEA,
          soft lilac #D6C7DA, dusty plum #A58BAA, deep plum #6E556F. Interior photography,
          quiet luxury, elevated. Photorealistic.
          → File: public/images/feng-shui-philosophy.jpg
        -->
        <Placeholder
          label="Bild generieren: Ruhige Raumecke in Flieder & Staumlila (#A58BAA, #D6C7DA, #F6F2F7)"
          ratio="4/5"
          class="philosophy-img"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       CTA BANNER
  ═══════════════════════════════════════════════════════════════ -->
  <section class="cta-banner" data-animate>
    <div class="container cta-inner">
      <h2>{f.cta.headline}</h2>
      <p>{f.cta.body}</p>
      <a href={f.cta.ctaHref} class="btn-primary btn-lg">{f.cta.cta}</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 80svh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--section-py) + 2rem);
    padding-bottom: var(--section-py);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: var(--color-sand-bg);
  }

  :global(.hero-bg-img) {
    width: 100% !important;
    height: 100% !important;
    aspect-ratio: unset !important;
    border-radius: 0 !important;
    border: none !important;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(246, 242, 247, 0.93) 0%,
      rgba(246, 242, 247, 0.80) 45%,
      rgba(214, 199, 218, 0.18) 100%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .hero-content { max-width: 640px; }

  .hero-content h1 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    color: var(--color-brown);
    margin: var(--space-4) 0 var(--space-6);
    white-space: pre-line;
  }

  .hero-content .lead {
    font-size: var(--text-md);
    color: var(--color-olive);
    margin-bottom: var(--space-8);
    max-width: none;
  }

  /* ── Buttons ─────────────────────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-olive);
    color: #fff;
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: background var(--transition), transform var(--transition);
  }
  .btn-primary:hover { background: var(--color-brown); transform: translateY(-1px); }
  .btn-primary.btn-lg { padding: var(--space-4) var(--space-10); font-size: var(--text-base); }

  /* ── Intro ───────────────────────────────────────────────────────── */
  .intro-section { background: var(--color-white); }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  @media (max-width: 768px) {
    .intro-grid { grid-template-columns: 1fr; gap: var(--space-8); }
  }

  .intro-text h2 {
    color: var(--color-brown);
    margin-bottom: var(--space-5);
  }

  .intro-text .lead { color: var(--color-olive); }

  .intro-quote {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-lg), 2.5vw, var(--text-2xl));
    font-style: italic;
    font-weight: 300;
    color: var(--color-olive);
    line-height: 1.5;
    border-left: 3px solid var(--color-clay);
    padding-left: var(--space-8);
    margin: 0;
  }

  /* ── Aspects ─────────────────────────────────────────────────────── */
  .aspects-section { background: var(--color-sand-subtle); }

  .section-header { margin-bottom: var(--space-12); }
  .section-header h2 { color: var(--color-brown); margin-top: var(--space-3); }

  .aspects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
  }

  .aspect-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-8) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    box-shadow: var(--shadow-sm);
  }

  .aspect-icon {
    font-size: 1.75rem;
    display: block;
  }

  .aspect-card h4 {
    color: var(--color-brown);
    font-size: var(--text-base);
    font-weight: 600;
    font-family: var(--font-body);
  }

  .aspect-card p {
    font-size: var(--text-sm);
    color: var(--color-olive);
    max-width: none;
    line-height: 1.6;
  }

  /* ── Philosophy ──────────────────────────────────────────────────── */
  .philosophy-section { background: var(--color-white); }

  .philosophy-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  @media (max-width: 768px) {
    .philosophy-inner { grid-template-columns: 1fr; gap: var(--space-8); }
    .philosophy-img-wrap { display: none; }
  }

  .philosophy-content h2 {
    color: var(--color-brown);
    margin: var(--space-3) 0 var(--space-5);
  }

  .philosophy-content .lead { color: var(--color-olive); margin-bottom: var(--space-8); }

  .philosophy-points {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .philosophy-point {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-olive);
    font-weight: 500;
  }

  .philosophy-point span:first-child { font-size: 1.25rem; }

  .philosophy-img-wrap {
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  :global(.philosophy-img) {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4/5;
    object-fit: cover;
    border-radius: var(--radius-lg);
    display: block;
  }

  /* ── CTA Banner ──────────────────────────────────────────────────── */
  .cta-banner {
    background: var(--color-brown);
    padding-block: var(--section-py);
    text-align: center;
  }

  .cta-inner { max-width: 600px; }

  .cta-banner h2 {
    color: #fff;
    margin-bottom: var(--space-4);
  }

  .cta-banner p {
    color: rgba(255,255,255,0.75);
    margin-inline: auto;
    margin-bottom: var(--space-8);
    max-width: none;
  }

  .cta-banner .btn-primary {
    background: var(--color-clay);
    color: #fff;
  }
  .cta-banner .btn-primary:hover {
    background: var(--color-sand);
    color: var(--color-brown);
  }
</style>

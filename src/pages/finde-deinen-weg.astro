---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n';

const tr = t('de');
const p  = tr.findYourPath;
---

<BaseLayout
  title={p.meta.title}
  description={p.meta.description}
  lang="de"
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content" data-animate>
        <span class="label">{p.hero.label}</span>
        <h1>{p.hero.headline}</h1>
        <p class="lead">{p.hero.body}</p>
      </div>
      <div class="hero-img-wrap" data-animate="scale" data-delay="200">
        <img
          src="/images/finde-deinen-weg.png"
          alt="Heller, ruhiger Flur mit Türdurchblick und warmem Licht"
          class="hero-img"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       OPTIONS
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section options-section">
    <div class="container">
      <p class="question" data-animate>{p.question}</p>
      <div class="options-grid">
        {p.options.map((option, i) => (
          <a
            href={option.href}
            class={`option-card option-card--${option.color}`}
            data-animate
            data-delay={`${i * 100}`}
          >
            <p class="option-feeling">„{option.feeling}"</p>
            <div class="option-answer">
              <h3>{option.answer}</h3>
              <p class="option-description">{option.description}</p>
            </div>
            <span class="option-cta">{option.cta} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────────────────── */
  .hero {
    background: var(--color-bg);
    padding-top: calc(var(--section-py) + 2rem);
    padding-bottom: var(--section-py);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
    .hero-img-wrap { display: none; }
  }

  .hero-content h1 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    margin: var(--space-4) 0 var(--space-6);
  }

  .hero-content .lead {
    font-size: var(--text-md);
    color: var(--color-text-muted);
  }

  .hero-img-wrap {
    display: flex;
    justify-content: center;
  }

  .hero-img {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 4/5;
    object-fit: cover;
    object-position: center;
    border-radius: var(--radius-lg);
    display: block;
  }

  /* ── Options ─────────────────────────────────────────────────────── */
  .options-section { background: var(--color-bg-alt); }

  .question {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-2xl));
    font-style: italic;
    color: var(--color-text);
    text-align: center;
    margin-bottom: var(--space-12);
    max-width: none;
  }

  .options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .option-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: transform var(--transition), box-shadow var(--transition);
    cursor: pointer;
  }

  .option-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  /* Branch colours */
  .option-card--blue   { background: var(--color-blue-subtle);  }
  .option-card--green  { background: var(--color-green-subtle); }
  .option-card--sand   { background: var(--color-sand-subtle);  }

  .option-feeling {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-style: italic;
    font-weight: 300;
    line-height: 1.5;
    max-width: none;
  }

  .option-card--blue   .option-feeling { color: var(--color-blue-heading); }
  .option-card--green  .option-feeling { color: var(--color-green-dark); }
  .option-card--sand   .option-feeling { color: var(--color-brown); }

  .option-answer { flex: 1; }

  .option-answer h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .option-card--blue   .option-answer h3 { color: var(--color-blue-heading); }
  .option-card--green  .option-answer h3 { color: var(--color-green-dark); }
  .option-card--sand   .option-answer h3 { color: var(--color-brown); }

  .option-description {
    font-size: var(--text-sm);
    line-height: 1.7;
    max-width: none;
  }

  .option-card--blue   .option-description { color: var(--color-blue-text); }
  .option-card--green  .option-description { color: var(--color-green); }
  .option-card--sand   .option-description { color: var(--color-olive); }

  .option-cta {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-top: auto;
  }

  .option-card--blue   .option-cta { color: var(--color-blue-dark); }
  .option-card--green  .option-cta { color: var(--color-green); }
  .option-card--sand   .option-cta { color: var(--color-olive); }
</style>

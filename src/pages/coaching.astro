---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n';

const tr = t('de');
const c  = tr.coaching;
---

<BaseLayout
  title={c.meta.title}
  description={c.meta.description}
  lang="de"
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content" data-animate>
        <span class="label">{c.hero.label}</span>
        <h1>{c.hero.headline}</h1>
        <p class="lead">{c.hero.body}</p>
        <a href="/kontakt" class="btn-primary">Kostenloses Erstgespräch</a>
      </div>
    </div>
    <div class="hero-accent" aria-hidden="true"></div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       INTRO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section intro-section">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-text" data-animate>
          <h2>{c.intro.headline}</h2>
          <p class="lead">{c.intro.body}</p>
        </div>
        <div class="intro-img-wrap" data-animate data-delay="150">
          <img
            src="/images/atmosphere-curtains.png"
            alt="Helles, ruhiges Zimmer mit sanftem Licht"
            class="intro-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       OFFERINGS
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section offerings-section">
    <div class="container">
      <div class="offerings-grid">
        {c.offerings.map((offering, i) => (
          <article class="offering-card" data-animate data-delay={i === 0 ? '0' : '150'}>
            <span class="offering-label">{offering.label}</span>
            <h3>{offering.headline}</h3>
            <div class="offering-body">
              {offering.body.split('\n\n').map(para => (
                <p>{para}</p>
              ))}
            </div>
            <dl class="offering-details">
              {offering.details.map(detail => (
                <div class="detail-row">
                  <dt>{detail.label}</dt>
                  <dd>{detail.value}</dd>
                </div>
              ))}
            </dl>
            <a href={offering.ctaHref} class="btn-outline">{offering.cta}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section faq-section">
    <div class="container faq-inner">
      <div class="faq-header" data-animate>
        <span class="label">{c.faq.label}</span>
        <h2>{c.faq.headline}</h2>
      </div>
      <div class="faq-list" data-animate data-delay="100">
        {c.faq.items.map(item => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <div class="faq-body"><p>{item.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       CTA BANNER
  ═══════════════════════════════════════════════════════════════ -->
  <section class="cta-banner" data-animate>
    <div class="container cta-inner">
      <h2>{c.cta.headline}</h2>
      <p>{c.cta.body}</p>
      <a href={c.cta.ctaHref} class="btn-primary btn-lg">{c.cta.cta}</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    background: var(--color-blue-bg);
    padding-top: calc(var(--section-py) + 2rem);
    padding-bottom: var(--section-py);
    overflow: hidden;
  }

  .hero-inner { position: relative; z-index: 1; }

  .hero-content { max-width: 640px; }

  .hero-content h1 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    color: var(--color-blue-heading);
    margin: var(--space-4) 0 var(--space-6);
    white-space: pre-line;
  }

  .hero-content .lead {
    font-size: var(--text-md);
    color: var(--color-blue-text);
    margin-bottom: var(--space-8);
  }

  .hero-accent {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 85% 50%, var(--color-blue-mist) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Buttons ─────────────────────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-blue-dark);
    color: #fff;
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: background var(--transition), transform var(--transition);
  }
  .btn-primary:hover { background: var(--color-blue); transform: translateY(-1px); }
  .btn-primary.btn-lg { padding: var(--space-4) var(--space-10); font-size: var(--text-base); }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: transparent;
    color: var(--color-blue-dark);
    border: 1.5px solid var(--color-blue-dark);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: background var(--transition), color var(--transition), transform var(--transition);
  }
  .btn-outline:hover {
    background: var(--color-blue-dark);
    color: #fff;
    transform: translateY(-1px);
  }

  /* ── Intro ───────────────────────────────────────────────────────── */
  .intro-section { background: var(--color-white); }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  @media (max-width: 768px) {
    .intro-grid { grid-template-columns: 1fr; gap: var(--space-8); }
  }

  .intro-text h2 {
    color: var(--color-blue-heading);
    margin-bottom: var(--space-5);
  }

  .intro-text .lead { color: var(--color-blue-text); }

  .intro-img-wrap {
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .intro-img {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4/5;
    object-fit: cover;
    object-position: center;
    border-radius: var(--radius-lg);
    display: block;
  }

  /* ── Offerings ───────────────────────────────────────────────────── */
  .offerings-section { background: var(--color-blue-subtle); }

  .offerings-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  @media (max-width: 768px) {
    .offerings-grid { grid-template-columns: 1fr; }
  }

  .offering-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-10) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    box-shadow: var(--shadow-sm);
  }

  .offering-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-blue-dark);
    background: var(--color-blue-subtle);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    align-self: flex-start;
  }

  .offering-card h3 {
    color: var(--color-blue-heading);
    font-size: var(--text-xl);
  }

  .offering-body { display: flex; flex-direction: column; gap: var(--space-4); }
  .offering-body p { color: var(--color-blue-text); max-width: none; }

  .offering-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-top: 1px solid var(--color-blue-subtle);
    padding-top: var(--space-5);
    margin-top: auto;
  }

  .detail-row {
    display: flex;
    gap: var(--space-4);
    font-size: var(--text-sm);
  }
  .detail-row dt {
    font-weight: 600;
    color: var(--color-blue-heading);
    min-width: 72px;
    flex-shrink: 0;
  }
  .detail-row dd { color: var(--color-blue-text); }

  /* ── FAQ ─────────────────────────────────────────────────────────── */
  .faq-section { background: var(--color-white); }

  .faq-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (max-width: 768px) {
    .faq-inner { grid-template-columns: 1fr; gap: var(--space-8); }
  }

  .faq-header h2 {
    color: var(--color-blue-heading);
    margin-top: var(--space-3);
  }

  .faq-list { display: flex; flex-direction: column; }

  /* ── CTA Banner ──────────────────────────────────────────────────── */
  .cta-banner {
    background: var(--color-blue-dark);
    padding-block: var(--section-py);
    text-align: center;
  }

  .cta-inner { max-width: 600px; }

  .cta-banner h2 {
    color: #fff;
    margin-bottom: var(--space-4);
  }

  .cta-banner p {
    color: rgba(255,255,255,0.75);
    margin-inline: auto;
    margin-bottom: var(--space-8);
    max-width: none;
  }

  .cta-banner .btn-primary {
    background: #fff;
    color: var(--color-blue-dark);
  }
  .cta-banner .btn-primary:hover {
    background: var(--color-blue-subtle);
  }
</style>

---
import Button from './Button.astro';

interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
  linkLabel?: string;
}

const { icon, title, description, href, linkLabel = 'Mehr erfahren' } = Astro.props;
---

<article class="service-card">
  <div class="service-icon" aria-hidden="true">{icon}</div>
  <h3>{title}</h3>
  <p>{description}</p>
  <Button href={href} variant="ghost">{linkLabel}</Button>
</article>

<style>
  .service-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-bg-muted);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .service-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .service-icon {
    font-size: 2rem;
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .service-card h3 {
    color: var(--color-text);
  }

  .service-card p {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    flex-grow: 1;
  }

  .service-card :global(.btn--ghost) {
    margin-top: var(--space-2);
    font-size: 0.9375rem;
  }
</style>

---
import { t, type Lang } from '../i18n';

interface Props { lang?: Lang; }
const { lang = 'de' } = Astro.props;
const tr = t(lang);

const base = lang === 'en' ? '/en' : '';
---

<footer class="footer">
  <div class="container footer-inner">

    <!-- Brand -->
    <div class="footer-brand" data-animate>
      <a href={`${base}/`} class="footer-logo-link" aria-label="Raum für dich">
        <img src="/images/logo-no-text.png" alt="" aria-hidden="true" class="footer-logo-img" />
      </a>
      <p class="footer-tagline">{tr.footer.tagline}</p>
    </div>

    <!-- Navigation -->
    <div class="footer-col" data-animate data-delay="100">
      <h4 class="footer-heading">{tr.footer.navigation}</h4>
      <ul class="footer-links" role="list">
        <li><a href={`${base}/coaching`}>{tr.nav.coaching}</a></li>
        <li><a href={`${base}/organizing`}>{tr.nav.organizing}</a></li>
        <li><a href={`${base}/feng-shui`}>{tr.nav.fengshui}</a></li>
        <li><a href={lang === 'en' ? '/en/find-your-path' : '/finde-deinen-weg'}>{tr.nav.findYourPath}</a></li>
        <li><a href={lang === 'en' ? '/en/about' : '/ueber-mich'}>{tr.nav.about}</a></li>
        <li><a href={lang === 'en' ? '/en/contact' : '/kontakt'}>{tr.nav.contact}</a></li>
      </ul>
    </div>

    <!-- Legal + Social -->
    <div class="footer-col" data-animate data-delay="200">
      <h4 class="footer-heading">{tr.footer.legal}</h4>
      <ul class="footer-links" role="list">
        <li><a href="/impressum">{tr.footer.impressum}</a></li>
        <li><a href="/datenschutz">{tr.footer.datenschutz}</a></li>
        <li><a href={lang === 'en' ? '/en/contact' : '/kontakt'}>{tr.footer.contact}</a></li>
      </ul>

      <div class="footer-social">
        <a href="#" class="social-link" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
          Instagram
        </a>
        <a href="#" class="social-link" aria-label="YouTube">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
            <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/>
          </svg>
          YouTube
        </a>
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>{tr.footer.rights}</span>
      <a href={tr.nav.langSwitchHref} class="footer-lang">{tr.nav.langSwitch}</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-text);
    color: rgba(255,255,255,0.55);
    padding-top: var(--space-20);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-16);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 480px) {
    .footer-inner { grid-template-columns: 1fr; }
  }

  .footer-brand { display: flex; flex-direction: column; gap: var(--space-4); }

  .footer-logo-link { display: inline-block; opacity: 0.6; transition: opacity var(--transition); }
  .footer-logo-link:hover { opacity: 1; }

  .footer-logo-img {
    height: 48px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .footer-tagline {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-style: italic;
    font-weight: 300;
    color: rgba(255,255,255,0.4);
    max-width: 24ch;
    line-height: 1.4;
  }

  .footer-heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: var(--space-5);
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .footer-links a {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-links a:hover { color: rgba(255,255,255,0.9); }

  .footer-social { display: flex; flex-direction: column; gap: var(--space-3); }

  .social-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color var(--transition);
  }

  .social-link:hover { color: rgba(255,255,255,0.9); }

  .footer-bottom { padding-block: var(--space-5); }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-bottom-inner span {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.3);
    max-width: none;
  }

  .footer-lang {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    padding: var(--space-1) var(--space-3);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-full);
    transition: color var(--transition), border-color var(--transition);
  }

  .footer-lang:hover {
    color: rgba(255,255,255,0.8);
    border-color: rgba(255,255,255,0.4);
  }
</style>

---
import Button from './Button.astro';

interface Props {
  headline: string;
  subline?: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
}

const {
  headline,
  subline,
  body,
  ctaLabel,
  ctaHref,
  ctaSecondaryLabel,
  ctaSecondaryHref,
} = Astro.props;
---

<section class="hero section--sand">
  <div class="container hero-inner">
    <div class="hero-content">
      <h1 data-animate>{headline}</h1>
      {subline && <p class="hero-subline" data-animate data-delay="100">{subline}</p>}
      {body && <p class="hero-body" data-animate data-delay="200">{body}</p>}
      {(ctaLabel || ctaSecondaryLabel) && (
        <div class="hero-actions" data-animate data-delay="300">
          {ctaLabel && ctaHref && (
            <Button href={ctaHref} variant="primary" size="large">
              {ctaLabel}
            </Button>
          )}
          {ctaSecondaryLabel && ctaSecondaryHref && (
            <Button href={ctaSecondaryHref} variant="secondary" size="large">
              {ctaSecondaryLabel}
            </Button>
          )}
        </div>
      )}
      <slot name="extra" />
    </div>

    <div data-animate="scale" data-delay="200">
      <slot name="image" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(var(--space-16), 8vw, var(--space-24));
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-inner:has(.hero-image) {
      grid-template-columns: 1fr 1fr;
    }

    .hero-inner :global(.hero-image) {
      width: 100%;
      max-height: 560px;
      object-fit: cover;
      border-radius: var(--radius-lg);
      display: block;
    }
  }

  .hero-content {
    max-width: 620px;
  }

  .hero-subline {
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    font-weight: 300;
    color: var(--color-gray-900);
    margin-top: var(--space-3);
    max-width: none;
    font-style: italic;
  }

  .hero-body {
    margin-top: var(--space-5);
    font-size: 1.0625rem;
    color: var(--color-gray-600);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
    align-items: center;
  }
</style>

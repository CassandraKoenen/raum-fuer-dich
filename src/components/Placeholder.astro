---
interface Props {
  label: string;
  ratio?: string;   // CSS aspect-ratio value, e.g. "4/5", "16/9", "1/1"
  class?: string;
}

const { label, ratio = '4/5', class: className } = Astro.props;
---

<figure
  class:list={['placeholder', className]}
  style={`aspect-ratio: ${ratio};`}
  aria-hidden="true"
>
  <svg class="placeholder-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Frame -->
    <rect x="4" y="8" width="40" height="32" rx="4" stroke="currentColor" stroke-width="1.5" fill="none"/>
    <!-- Sun -->
    <circle cx="16" cy="18" r="4" stroke="currentColor" stroke-width="1.5" fill="none"/>
    <!-- Mountains -->
    <polyline points="4,40 16,24 26,34 32,27 44,40" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
  </svg>
  <span class="placeholder-label">{label}</span>
</figure>

<style>
  .placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: var(--color-bg-alt);
    border: 2px dashed var(--color-accent-light);
    border-radius: var(--radius-lg);
    color: var(--color-accent);
    width: 100%;
    overflow: hidden;
    user-select: none;
  }

  .placeholder-icon {
    width: clamp(2rem, 6%, 3rem);
    height: auto;
    opacity: 0.6;
  }

  .placeholder-label {
    font-size: clamp(0.625rem, 1.5vw, 0.8125rem);
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-accent-dark);
    opacity: 0.7;
    text-align: center;
    padding-inline: 1rem;
  }
</style>
